[Unit]
Description=updating repository aurbuild in user context

[Service]
Type=oneshot
StandardOutput=truncate:/srv/aurbuild/aurbuild.log
StandardError=truncate:/srv/aurbuild/aurbuild_error.log
ExecStart=%h/.local/share/repos/shell/aurbuild.sh

[Install]
WantedBy=multi-user.target
